# Netlify redirects for Django Book Management System

# Redirect root to public home
/ /public/index.html 200

# Handle manager authentication (redirect to static notice)
/manager/login/ /static-notice.html 200
/manager/admin/ /static-notice.html 200

# Public routes - serve static files
/public/* /public/:splat 200

# Handle dynamic routes with static fallbacks
/public/authors/* /public/authors/index.html 200
/public/publishers/* /public/publishers/index.html 200
/public/books/* /public/books/index.html 200

# Fallback for any unmatched routes
/* /public/index.html 200
